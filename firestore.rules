rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. SanPham Collection Security Rules
    match /SanPham/{productId} {
      allow read: if true;
      allow create: if isValidSanPham(request.resource.data);
      allow update: if isValidSanPham(request.resource.data);
      allow delete: if true;
    }
  }
}

// Validation helper for SanPham documents
function isValidSanPham(data) {
  return data != null
    && data.keys().hasAll(['ten_san_pham', 'gia'])
    && data.ten_san_pham is string 
    && data.ten_san_pham.size() > 0 
    && data.ten_san_pham.size() <= 200
    && data.gia is string 
    && data.gia.size() > 0 
    && data.gia.size() <= 100
    && (!data.keys().hasAny(['chiet_khau']) || (data.chiet_khau is string && data.chiet_khau.size() <= 10))
    && (!data.keys().hasAny(['mo_ta']) || (data.mo_ta is string && data.mo_ta.size() <= 2000))
    && (!data.keys().hasAny(['loai_san_pham']) || (data.loai_san_pham is string && data.loai_san_pham.size() <= 50))
    && (!data.keys().hasAny(['hinh_anh']) || (data.hinh_anh is string && data.hinh_anh.size() <= 1000));
}
